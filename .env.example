# Copy this to .env.local and fill in your values

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# For local dev: postgresql://postgres:password@localhost:5432/travelusaexpress
# For Vercel + Neon/Supabase: use the connection string from your dashboard
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/travelusaexpress?schema=public"

# Next.js
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
